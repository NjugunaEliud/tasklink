// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  TASKER
  ADMIN
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_CONFIRMATION
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum TransactionType {
  ESCROW_IN
  ESCROW_OUT
  PLATFORM_FEE
  REFUND
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  phone     String?
  avatar    String?
  bio       String?
  skills    String[]
  portfolio String?
  suspended Boolean  @default(false)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasksPosted     Task[]        @relation("ClientTasks")
  assignedTasks   Task[]        @relation("AssignedTasker")
  proposals       Proposal[]    @relation("TaskerProposals")
  escrowsAsClient Escrow[]      @relation("ClientEscrow")
  escrowsAsTasker Escrow[]      @relation("TaskerEscrow")
  transactions    Transaction[]
  messagesSent    Message[]     @relation("SentMessages")
  messagesReceived Message[]    @relation("ReceivedMessages")
  reviewsGiven    Review[]      @relation("ClientReviews")
  reviewsReceived Review[]      @relation("TaskerReviews")
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  icon  String @default("briefcase")
  tasks Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String
  budget      Float
  deadline    DateTime
  status      TaskStatus @default(OPEN)
  attachments String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  client     User      @relation("ClientTasks", fields: [clientId], references: [id])
  clientId   String
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  tasker     User?     @relation("AssignedTasker", fields: [taskerId], references: [id])
  taskerId   String?

  proposals    Proposal[]
  escrow       Escrow?
  transactions Transaction[]
  messages     Message[]
  review       Review?
}

// Workaround for the optional relation - add a back-relation to User
// We handle the assigned tasker via the Proposal accept flow

model Proposal {
  id                String         @id @default(cuid())
  message           String
  estimatedDuration String
  status            ProposalStatus @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  task     Task   @relation(fields: [taskId], references: [id])
  taskId   String
  tasker   User   @relation("TaskerProposals", fields: [taskerId], references: [id])
  taskerId String
}

model Escrow {
  id        String       @id @default(cuid())
  amount    Float
  status    EscrowStatus @default(HELD)
  mpesaRef  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  task     Task   @relation(fields: [taskId], references: [id])
  taskId   String @unique
  client   User   @relation("ClientEscrow", fields: [clientId], references: [id])
  clientId String
  tasker   User   @relation("TaskerEscrow", fields: [taskerId], references: [id])
  taskerId String
}

model Transaction {
  id        String          @id @default(cuid())
  type      TransactionType
  amount    Float
  fee       Float           @default(0)
  mpesaRef  String?
  createdAt DateTime        @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String
  task   Task   @relation(fields: [taskId], references: [id])
  taskId String
}

model Message {
  id        String   @id @default(cuid())
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())

  sender     User   @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String
  task       Task   @relation(fields: [taskId], references: [id])
  taskId     String
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  client   User   @relation("ClientReviews", fields: [clientId], references: [id])
  clientId String
  tasker   User   @relation("TaskerReviews", fields: [taskerId], references: [id])
  taskerId String
  task     Task   @relation(fields: [taskId], references: [id])
  taskId   String @unique
}
